<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_contract_form_gt_estado_cuenta" model="ir.ui.view">
        <field name="name">hr.contract.form.gt.estado.cuenta</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button class="oe_stat_button" type="object"
                        name="action_l10n_gt_view_payslips" icon="fa-calendar">
                    <field name="l10n_gt_payslip_count" widget="statinfo"
                           string="Periodos"/>
                </button>
                <button class="oe_stat_button" type="object"
                        name="action_l10n_gt_view_payslips" icon="fa-balance-scale">
                    <div class="o_stat_info">
                        <field name="l10n_gt_pending_total" widget="monetary"
                               class="o_stat_value"/>
                        <span class="o_stat_text">Pendiente</span>
                    </div>
                </button>
                <field name="currency_id" invisible="1"/>
            </div>
            <xpath expr="//header" position="inside">
                <button name="action_l10n_gt_estado_cuenta" type="object"
                        string="Estado de cuenta" class="btn-secondary"/>
            </xpath>
        </field>
    </record>

</odoo>
