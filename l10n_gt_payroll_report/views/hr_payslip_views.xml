<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_payslip_form_gt_quincena" model="ir.ui.view">
        <field name="name">hr.payslip.form.gt.quincena</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">
            <field name="struct_id" position="after">
                <field name="l10n_gt_payment_frequency"/>
                <field name="l10n_gt_unpaid_days"/>
            </field>

            <notebook position="inside">
                <page string="Estado de cuenta / Pagos" name="l10n_gt_estado_cuenta">
                    <div class="alert alert-info" role="alert">
                        El recibo calcula el <b>líquido del mes</b> (IGSS, ISR,
                        contabilidad y Libro de Salarios). Aquí llevas el
                        <b>estado de cuenta</b>: registra cada pago y márcalo como
                        <b>Pagado</b> al entregarlo. El <b>saldo pendiente</b> =
                        líquido − pagado; si reduces días (faltas) el líquido baja y
                        la reducción recae sobre el saldo pendiente, sin afectar lo
                        ya pagado. Imprime el comprobante de cada pago para que el
                        trabajador lo firme.
                    </div>

                    <group>
                        <group string="Reparto (según el contrato)">
                            <field name="l10n_gt_payment_frequency"/>
                            <field name="l10n_gt_quincena_method"
                                   invisible="l10n_gt_payment_frequency != 'biweekly'"/>
                            <field name="l10n_gt_first_quincena_amount"
                                   invisible="l10n_gt_payment_frequency != 'biweekly' or l10n_gt_quincena_method != 'manual'"/>
                        </group>
                        <group string="Resumen">
                            <field name="l10n_gt_net_amount"/>
                            <field name="l10n_gt_paid_amount"/>
                            <field name="l10n_gt_pending_amount"/>
                        </group>
                    </group>

                    <button name="action_l10n_gt_generar_pagos" type="object"
                            string="Generar programación de pagos" icon="fa-refresh"
                            class="btn-secondary"
                            help="Crea/actualiza las líneas pendientes según la frecuencia y el método. No toca lo ya marcado como pagado."/>

                    <field name="l10n_gt_payment_ids" class="mt-2">
                        <list editable="bottom">
                            <field name="date"/>
                            <field name="name"/>
                            <field name="amount" sum="Total"/>
                            <field name="paid" widget="boolean_toggle"/>
                            <field name="reference"/>
                            <field name="signed_doc" filename="signed_doc_name"
                                   widget="binary" string="Firmado"/>
                            <field name="signed_doc_name" column_invisible="1"/>
                            <button name="%(l10n_gt_payroll_report.action_report_comprobante_pago)d"
                                    type="action" icon="fa-print"
                                    string="Comprobante" class="btn-link"/>
                        </list>
                    </field>
                </page>
            </notebook>
        </field>
    </record>

</odoo>
