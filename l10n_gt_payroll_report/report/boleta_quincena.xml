<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Comprobante de quincena (formato anexo 8.2). El cálculo es mensual; este
         comprobante muestra el mes y paga la quincena correspondiente (líquido/2). -->

    <record id="action_report_boleta_q1" model="ir.actions.report">
        <field name="name">Comprobante 1ª Quincena</field>
        <field name="model">hr.payslip</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">l10n_gt_payroll_report.report_boleta_q1</field>
        <field name="report_file">l10n_gt_payroll_report.report_boleta_q1</field>
        <field name="binding_model_id" ref="hr_payroll.model_hr_payslip"/>
        <field name="binding_type">report</field>
    </record>

    <record id="action_report_boleta_q2" model="ir.actions.report">
        <field name="name">Comprobante 2ª Quincena</field>
        <field name="model">hr.payslip</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">l10n_gt_payroll_report.report_boleta_q2</field>
        <field name="report_file">l10n_gt_payroll_report.report_boleta_q2</field>
        <field name="binding_model_id" ref="hr_payroll.model_hr_payslip"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Cuerpo común: espera 'doc' y 'quincena' (1 o 2) -->
    <template id="boleta_quincena_body">
        <t t-set="qd" t-value="doc._l10n_gt_quincena_dates(quincena)"/>
        <t t-set="pagado" t-value="doc._l10n_gt_quincena_amount(quincena)"/>
        <div class="page">
            <t t-set="subtitulo"
               t-value="'Comprobante de Pago — %s Quincena' % ('Primera' if quincena == 1 else 'Segunda')"/>
            <t t-call="l10n_gt_payroll_report.l10n_gt_boleta_encabezado"/>
            <div class="mb-2" style="font-size:12px;">
                <strong>Mes calculado:</strong>
                <span t-field="doc.date_from"/> al <span t-field="doc.date_to"/>
                <span class="mx-3">·</span>
                <strong>Pago de la quincena:</strong>
                <span t-esc="qd[0]"/> al <span t-esc="qd[1]"/>
            </div>

            <t t-call="l10n_gt_payroll_report.l10n_gt_devengados_grid"/>

            <!-- Fila de descuentos + quincenas -->
            <table class="table table-sm table-bordered text-center mb-0"
                   style="font-size:11px;">
                <thead style="background-color:#d9d9d9;">
                    <tr>
                        <th>I.S.R.</th>
                        <th>IGSS</th>
                        <th>Prestamos</th>
                        <th>Anticipos</th>
                        <th>Otros</th>
                        <th>Total<br/>Descuentos</th>
                        <th>Primera<br/>Quincena</th>
                        <th>Segunda<br/>Quincena</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <t t-set="isr" t-value="doc._l10n_gt_line_abs('ISR')"/>
                        <t t-set="prest" t-value="doc._l10n_gt_line_abs('PREST')"/>
                        <t t-set="antic" t-value="doc._l10n_gt_line_abs('ANTIC')"/>
                        <t t-set="otros" t-value="doc._l10n_gt_line_abs('OTRDED')"/>
                        <td class="text-end"><span t-esc="('%.2f' % isr) if isr else '-'"/></td>
                        <td class="text-end"><span t-esc="'%.2f' % doc._l10n_gt_line_abs('IGSSLAB')"/></td>
                        <td class="text-end"><span t-esc="('%.2f' % prest) if prest else '-'"/></td>
                        <td class="text-end"><span t-esc="('%.2f' % antic) if antic else '-'"/></td>
                        <td class="text-end"><span t-esc="('%.2f' % otros) if otros else '-'"/></td>
                        <td class="text-end fw-bold"><span t-esc="'%.2f' % doc._l10n_gt_lines_by_category('DED','out')"/></td>
                        <td class="text-end"><span t-esc="'%.2f' % doc._l10n_gt_quincena_amount(1)"/></td>
                        <td class="text-end"><span t-esc="'%.2f' % doc._l10n_gt_quincena_amount(2)"/></td>
                    </tr>
                    <tr>
                        <td colspan="6" class="text-end fw-bold"
                            style="background-color:#d9d9d9;">TOTAL (esta quincena)</td>
                        <td colspan="2" class="text-end fw-bold"
                            style="background-color:#d9d9d9;">
                            <span t-esc="'%.2f' % pagado"/></td>
                    </tr>
                </tbody>
            </table>

            <t t-call="l10n_gt_payroll_report.l10n_gt_boleta_pie"/>
        </div>
    </template>

    <template id="report_boleta_q1">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <t t-set="quincena" t-value="1"/>
                    <t t-call="l10n_gt_payroll_report.boleta_quincena_body"/>
                </t>
            </t>
        </t>
    </template>

    <template id="report_boleta_q2">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <t t-set="quincena" t-value="2"/>
                    <t t-call="l10n_gt_payroll_report.boleta_quincena_body"/>
                </t>
            </t>
        </t>
    </template>

</odoo>
