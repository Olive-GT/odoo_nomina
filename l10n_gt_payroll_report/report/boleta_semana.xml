<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Comprobantes semanales (para contratos con frecuencia Semanal).
         El cálculo es mensual; cada comprobante paga la semana correspondiente. -->

    <record id="action_report_boleta_w1" model="ir.actions.report">
        <field name="name">Comprobante Semana 1</field>
        <field name="model">hr.payslip</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">l10n_gt_payroll_report.report_boleta_w1</field>
        <field name="report_file">l10n_gt_payroll_report.report_boleta_w1</field>
        <field name="binding_model_id" ref="hr_payroll.model_hr_payslip"/>
        <field name="binding_type">report</field>
    </record>
    <record id="action_report_boleta_w2" model="ir.actions.report">
        <field name="name">Comprobante Semana 2</field>
        <field name="model">hr.payslip</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">l10n_gt_payroll_report.report_boleta_w2</field>
        <field name="report_file">l10n_gt_payroll_report.report_boleta_w2</field>
        <field name="binding_model_id" ref="hr_payroll.model_hr_payslip"/>
        <field name="binding_type">report</field>
    </record>
    <record id="action_report_boleta_w3" model="ir.actions.report">
        <field name="name">Comprobante Semana 3</field>
        <field name="model">hr.payslip</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">l10n_gt_payroll_report.report_boleta_w3</field>
        <field name="report_file">l10n_gt_payroll_report.report_boleta_w3</field>
        <field name="binding_model_id" ref="hr_payroll.model_hr_payslip"/>
        <field name="binding_type">report</field>
    </record>
    <record id="action_report_boleta_w4" model="ir.actions.report">
        <field name="name">Comprobante Semana 4</field>
        <field name="model">hr.payslip</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">l10n_gt_payroll_report.report_boleta_w4</field>
        <field name="report_file">l10n_gt_payroll_report.report_boleta_w4</field>
        <field name="binding_model_id" ref="hr_payroll.model_hr_payslip"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Cuerpo común: espera 'doc' y 'semana' (1-4) -->
    <template id="boleta_semana_body">
        <t t-set="sd" t-value="doc._l10n_gt_semana_dates(semana)"/>
        <t t-set="pagado" t-value="doc._l10n_gt_semana_amount(semana)"/>
        <div class="page">
            <t t-set="subtitulo"
               t-value="'Comprobante de Pago — Semana %s' % semana"/>
            <t t-call="l10n_gt_payroll_report.l10n_gt_boleta_encabezado"/>
            <div class="mb-2" style="font-size:12px;">
                <strong>Mes calculado:</strong>
                <span t-field="doc.date_from"/> al <span t-field="doc.date_to"/>
                <span class="mx-3">·</span>
                <strong>Pago de la semana:</strong>
                <span t-esc="sd[0]"/> al <span t-esc="sd[1]"/>
            </div>

            <t t-call="l10n_gt_payroll_report.l10n_gt_devengados_grid"/>

            <table class="table table-sm table-bordered text-center mb-0"
                   style="font-size:11px;">
                <thead style="background-color:#d9d9d9;">
                    <tr>
                        <th>I.S.R.</th>
                        <th>IGSS</th>
                        <th>Prestamos</th>
                        <th>Anticipos</th>
                        <th>Otros</th>
                        <th>Total<br/>Descuentos</th>
                        <th>Líquido<br/>del Mes</th>
                        <th>A Pagar<br/>(Semana <span t-esc="semana"/>)</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <t t-set="isr" t-value="doc._l10n_gt_line_abs('ISR')"/>
                        <t t-set="prest" t-value="doc._l10n_gt_line_abs('PREST')"/>
                        <t t-set="antic" t-value="doc._l10n_gt_line_abs('ANTIC')"/>
                        <t t-set="otros" t-value="doc._l10n_gt_line_abs('OTRDED')"/>
                        <td class="text-end"><span t-esc="('%.2f' % isr) if isr else '-'"/></td>
                        <td class="text-end"><span t-esc="'%.2f' % doc._l10n_gt_line_abs('IGSSLAB')"/></td>
                        <td class="text-end"><span t-esc="('%.2f' % prest) if prest else '-'"/></td>
                        <td class="text-end"><span t-esc="('%.2f' % antic) if antic else '-'"/></td>
                        <td class="text-end"><span t-esc="('%.2f' % otros) if otros else '-'"/></td>
                        <td class="text-end fw-bold"><span t-esc="'%.2f' % doc._l10n_gt_lines_by_category('DED','out')"/></td>
                        <td class="text-end"><span t-esc="'%.2f' % doc._l10n_gt_line('NET')"/></td>
                        <td class="text-end fw-bold"
                            style="background-color:#d9d9d9;">
                            <span t-esc="'%.2f' % pagado"/></td>
                    </tr>
                </tbody>
            </table>

            <t t-call="l10n_gt_payroll_report.l10n_gt_boleta_pie"/>
        </div>
    </template>

    <template id="report_boleta_w1">
        <t t-call="web.html_container"><t t-foreach="docs" t-as="doc">
            <t t-call="web.external_layout"><t t-set="semana" t-value="1"/>
                <t t-call="l10n_gt_payroll_report.boleta_semana_body"/></t>
        </t></t>
    </template>
    <template id="report_boleta_w2">
        <t t-call="web.html_container"><t t-foreach="docs" t-as="doc">
            <t t-call="web.external_layout"><t t-set="semana" t-value="2"/>
                <t t-call="l10n_gt_payroll_report.boleta_semana_body"/></t>
        </t></t>
    </template>
    <template id="report_boleta_w3">
        <t t-call="web.html_container"><t t-foreach="docs" t-as="doc">
            <t t-call="web.external_layout"><t t-set="semana" t-value="3"/>
                <t t-call="l10n_gt_payroll_report.boleta_semana_body"/></t>
        </t></t>
    </template>
    <template id="report_boleta_w4">
        <t t-call="web.html_container"><t t-foreach="docs" t-as="doc">
            <t t-call="web.external_layout"><t t-set="semana" t-value="4"/>
                <t t-call="l10n_gt_payroll_report.boleta_semana_body"/></t>
        </t></t>
    </template>

</odoo>
