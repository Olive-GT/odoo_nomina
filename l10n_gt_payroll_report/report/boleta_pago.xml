<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Rejilla DEVENGADOS compartida por las boletas mensual/quincena/semana.
         Espera 'doc'. Muestra el cálculo del MES (IGSS/ISR son mensuales). -->
    <template id="l10n_gt_devengados_grid">
        <div class="text-center fw-bold border p-1"
             style="background-color:#1f3864; color:#ffffff; letter-spacing:1px;">
            DEVENGADOS DEL MES</div>
        <table class="table table-sm table-bordered text-center mb-0"
               style="font-size:11px;">
            <thead style="background-color:#dbe5f1;">
                <tr>
                    <th rowspan="2" class="align-middle">Días<br/>Pagados</th>
                    <th colspan="2">Devengado</th>
                    <th rowspan="2" class="align-middle">Horas<br/>Extras</th>
                    <th rowspan="2" class="align-middle">Bonificación<br/>Trimestral</th>
                    <th rowspan="2" class="align-middle">Bonificación<br/>Dto. 37-2001</th>
                    <th rowspan="2" class="align-middle">Total<br/>Devengados</th>
                </tr>
                <tr>
                    <th>Ordinario</th>
                    <th>Extra</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <t t-set="ordi" t-value="doc._l10n_gt_line('SALORD')"/>
                    <t t-set="extra" t-value="doc._l10n_gt_line('COMIS')"/>
                    <t t-set="he" t-value="doc._l10n_gt_line('HEXTD') + doc._l10n_gt_line('HEXTN')"/>
                    <t t-set="botri" t-value="doc._l10n_gt_line('BONIF')"/>
                    <td><span t-esc="'%g' % doc._l10n_gt_paid_days()"/></td>
                    <td class="text-end"><span t-esc="('%.2f' % ordi) if ordi else '-'"/></td>
                    <td class="text-end"><span t-esc="('%.2f' % extra) if extra else '-'"/></td>
                    <td class="text-end"><span t-esc="('%.2f' % he) if he else '-'"/></td>
                    <td class="text-end"><span t-esc="('%.2f' % botri) if botri else '-'"/></td>
                    <td class="text-end"><span t-esc="'%.2f' % doc._l10n_gt_line('BONINC')"/></td>
                    <td class="text-end fw-bold"><span t-esc="'%.2f' % doc._l10n_gt_line('GROSS')"/></td>
                </tr>
            </tbody>
        </table>
    </template>

    <!-- Encabezado profesional con banda de empresa + datos del empleado.
         Espera 'doc' y 'subtitulo'. -->
    <template id="l10n_gt_boleta_encabezado">
        <div class="text-center py-2 mb-0"
             style="background-color:#1f3864; color:#ffffff;">
            <div style="font-size:16px; font-weight:bold; letter-spacing:1px;"
                 t-field="doc.company_id.name"/>
            <div style="font-size:12px;" t-esc="subtitulo"/>
        </div>
        <table class="table table-sm table-bordered mb-2" style="font-size:11px;">
            <tr>
                <td style="width:12%; background-color:#dbe5f1;"><strong>Empleado</strong></td>
                <td style="width:38%;"><span t-field="doc.employee_id.name"/></td>
                <td style="width:12%; background-color:#dbe5f1;"><strong>No. Recibo</strong></td>
                <td style="width:13%;"><span t-field="doc.number"/></td>
                <td style="width:12%; background-color:#dbe5f1;"><strong>Código</strong></td>
                <td style="width:13%;"><span t-field="doc.employee_id.barcode"/></td>
            </tr>
            <tr>
                <td style="background-color:#dbe5f1;"><strong>DPI</strong></td>
                <td><span t-field="doc.employee_id.l10n_gt_dpi"/></td>
                <td style="background-color:#dbe5f1;"><strong>Puesto</strong></td>
                <td><span t-field="doc.employee_id.job_id.name"/></td>
                <td style="background-color:#dbe5f1;"><strong>Departamento</strong></td>
                <td><span t-field="doc.employee_id.department_id.name"/></td>
            </tr>
        </table>
    </template>

    <!-- Rejilla DESCUENTOS del mes compartida. Espera 'doc'. -->
    <template id="l10n_gt_descuentos_grid">
        <table class="table table-sm table-bordered text-center mb-0"
               style="font-size:11px;">
            <thead style="background-color:#dbe5f1;">
                <tr>
                    <th>I.S.R.</th>
                    <th>IGSS</th>
                    <th>Prestamos</th>
                    <th>Anticipos</th>
                    <th>Otros</th>
                    <th>Total<br/>Descuentos</th>
                    <th>Líquido<br/>del Mes</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <t t-set="isr" t-value="doc._l10n_gt_line_abs('ISR')"/>
                    <t t-set="prest" t-value="doc._l10n_gt_line_abs('PREST')"/>
                    <t t-set="antic" t-value="doc._l10n_gt_line_abs('ANTIC')"/>
                    <t t-set="otros" t-value="doc._l10n_gt_line_abs('OTRDED')"/>
                    <td class="text-end"><span t-esc="('%.2f' % isr) if isr else '-'"/></td>
                    <td class="text-end"><span t-esc="'%.2f' % doc._l10n_gt_line_abs('IGSSLAB')"/></td>
                    <td class="text-end"><span t-esc="('%.2f' % prest) if prest else '-'"/></td>
                    <td class="text-end"><span t-esc="('%.2f' % antic) if antic else '-'"/></td>
                    <td class="text-end"><span t-esc="('%.2f' % otros) if otros else '-'"/></td>
                    <td class="text-end fw-bold"><span t-esc="'%.2f' % doc._l10n_gt_lines_by_category('DED','out')"/></td>
                    <td class="text-end fw-bold" style="background-color:#dbe5f1;">
                        <span t-esc="'%.2f' % doc._l10n_gt_line('NET')"/></td>
                </tr>
            </tbody>
        </table>
    </template>

    <!-- Estado de cuenta: pagos del mes + saldo. Espera 'doc' (recibo) y opcional
         'resaltar' (id de la línea de pago a resaltar). -->
    <template id="l10n_gt_estado_cuenta">
        <div class="text-center fw-bold border p-1 mt-2"
             style="background-color:#1f3864; color:#ffffff; letter-spacing:1px;">
            ESTADO DE CUENTA DEL MES</div>
        <table class="table table-sm table-bordered mb-0" style="font-size:11px;">
            <thead style="background-color:#dbe5f1;">
                <tr>
                    <th>Fecha</th>
                    <th>Concepto</th>
                    <th class="text-end">Monto</th>
                    <th class="text-center">Estado</th>
                </tr>
            </thead>
            <tbody>
                <tr t-foreach="doc.l10n_gt_payment_ids" t-as="pg"
                    t-att-style="'background-color:#fff2cc;' if resaltar and pg.id == resaltar else ''">
                    <td><span t-field="pg.date"/></td>
                    <td><span t-field="pg.name"/></td>
                    <td class="text-end"><span t-esc="'%.2f' % pg.amount"/></td>
                    <td class="text-center">
                        <span t-esc="'Pagado' if pg.paid else 'Pendiente'"/></td>
                </tr>
                <tr class="fw-bold">
                    <td colspan="2" class="text-end">Líquido del mes</td>
                    <td class="text-end"><span t-esc="'%.2f' % doc.l10n_gt_net_amount"/></td>
                    <td/>
                </tr>
                <tr class="fw-bold">
                    <td colspan="2" class="text-end">Total pagado</td>
                    <td class="text-end"><span t-esc="'%.2f' % doc.l10n_gt_paid_amount"/></td>
                    <td/>
                </tr>
                <tr class="fw-bold" style="background-color:#dbe5f1;">
                    <td colspan="2" class="text-end">Saldo pendiente</td>
                    <td class="text-end"><span t-esc="'%.2f' % doc.l10n_gt_pending_amount"/></td>
                    <td/>
                </tr>
            </tbody>
        </table>
    </template>

    <!-- Pie: valor en letras + conformidad + firma. Espera 'doc' y 'pagado'. -->
    <template id="l10n_gt_boleta_pie">
        <p class="mt-2 mb-3" style="font-size:12px;">
            <strong>Valor en letras:</strong>
            <span t-esc="doc._l10n_gt_amount_words(pagado)"/>
        </p>
        <p style="font-size:11px; text-align:justify;">
            Recibí de conformidad el importe neto indicado y acepto esta liquidación,
            la cual cubre la totalidad de los servicios prestados y asignados durante
            el período a que se refiere.
        </p>
        <div class="row mt-5">
            <div class="col-6 offset-3 text-center">
                <p class="mb-0">_______________________________</p>
                <p class="mb-0">Recibí Conforme</p>
                <p class="fw-bold"><span t-field="doc.employee_id.name"/></p>
            </div>
        </div>
    </template>

    <!-- §6.1 Boleta de pago mensual (formato anexo 8.2) -->
    <template id="report_boleta">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <t t-set="pagado" t-value="doc._l10n_gt_line('NET')"/>
                    <div class="page">
                        <t t-set="subtitulo" t-value="'Comprobante de Pago Mensual'"/>
                        <t t-call="l10n_gt_payroll_report.l10n_gt_boleta_encabezado"/>
                        <div class="mb-2" style="font-size:12px;">
                            <strong>Período:</strong>
                            <span t-field="doc.date_from"/> al <span t-field="doc.date_to"/>
                        </div>

                        <t t-call="l10n_gt_payroll_report.l10n_gt_devengados_grid"/>
                        <t t-call="l10n_gt_payroll_report.l10n_gt_descuentos_grid"/>
                        <t t-set="resaltar" t-value="False"/>
                        <t t-if="doc.l10n_gt_payment_ids"
                           t-call="l10n_gt_payroll_report.l10n_gt_estado_cuenta"/>

                        <t t-call="l10n_gt_payroll_report.l10n_gt_boleta_pie"/>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
