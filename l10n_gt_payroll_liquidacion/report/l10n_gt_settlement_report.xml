<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_settlement" model="ir.actions.report">
        <field name="name">Finiquito de liquidación</field>
        <field name="model">l10n.gt.settlement</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">l10n_gt_payroll_liquidacion.report_settlement</field>
        <field name="report_file">l10n_gt_payroll_liquidacion.report_settlement</field>
        <field name="binding_model_id" ref="model_l10n_gt_settlement"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_settlement">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 class="text-center">LIQUIDACIÓN — PAGO DE PRESTACIONES</h2>
                        <div class="row mt-4">
                            <div class="col-6">
                                <p><strong>Nombre:</strong> <span t-field="doc.employee_id.name"/></p>
                                <p><strong>DPI:</strong> <span t-field="doc.employee_id.l10n_gt_dpi"/></p>
                                <p><strong>Motivo:</strong> <span t-field="doc.reason"/></p>
                            </div>
                            <div class="col-6">
                                <p><strong>Fecha de ingreso:</strong> <span t-field="doc.date_start"/></p>
                                <p><strong>Fecha de retiro:</strong> <span t-field="doc.date_end"/></p>
                                <p><strong>Años laborados:</strong> <span t-field="doc.years_worked"/></p>
                                <p><strong>Sueldo diario:</strong> <span t-field="doc.daily_wage"/></p>
                            </div>
                        </div>

                        <table class="table table-sm mt-4">
                            <thead>
                                <tr><th>Concepto</th><th class="text-end">Monto</th></tr>
                            </thead>
                            <tbody>
                                <tr><td>Salario ordinario pendiente</td>
                                    <td class="text-end"><span t-field="doc.salario_pendiente"/></td></tr>
                                <tr><td>Bonificación incentivo pendiente</td>
                                    <td class="text-end"><span t-field="doc.bonif_pendiente"/></td></tr>
                                <tr><td>Aguinaldo proporcional</td>
                                    <td class="text-end"><span t-field="doc.aguinaldo_prop"/></td></tr>
                                <tr><td>Bono 14 proporcional</td>
                                    <td class="text-end"><span t-field="doc.bono14_prop"/></td></tr>
                                <tr><td>Vacaciones pendientes</td>
                                    <td class="text-end"><span t-field="doc.vacaciones"/></td></tr>
                                <tr t-if="doc.has_indemnity"><td>Indemnización</td>
                                    <td class="text-end"><span t-field="doc.indemnizacion"/></td></tr>
                                <tr class="fw-bold"><td>Total prestaciones e ingresos</td>
                                    <td class="text-end"><span t-field="doc.total_ingresos"/></td></tr>
                                <tr><td>(-) IGSS laboral</td>
                                    <td class="text-end"><span t-field="doc.igss_pendiente"/></td></tr>
                                <tr><td>(-) ISR</td>
                                    <td class="text-end"><span t-field="doc.isr_pendiente"/></td></tr>
                                <tr><td>(-) Anticipos pendientes</td>
                                    <td class="text-end"><span t-field="doc.anticipos_pendientes"/></td></tr>
                                <tr><td>(-) Préstamos pendientes</td>
                                    <td class="text-end"><span t-field="doc.prestamos_pendientes"/></td></tr>
                                <tr class="fw-bold"><td>Total descuentos</td>
                                    <td class="text-end"><span t-field="doc.total_descuentos"/></td></tr>
                                <tr class="fw-bold table-active"><td>TOTAL LIQUIDACIÓN A PAGAR</td>
                                    <td class="text-end"><span t-field="doc.total_liquidacion"/></td></tr>
                            </tbody>
                        </table>

                        <div class="row mt-5">
                            <div class="col-6 offset-3 text-center">
                                <p>_______________________________</p>
                                <p>Recibí conforme<br/><span t-field="doc.employee_id.name"/></p>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
