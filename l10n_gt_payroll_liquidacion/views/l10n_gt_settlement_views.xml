<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- El finiquito es un recibo de liquidación: campos de retiro + botón para
         calcular las prestaciones proporcionales e indemnización. -->
    <record id="view_payslip_form_gt_settlement" model="ir.ui.view">
        <field name="name">hr.payslip.form.gt.settlement</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id"
               ref="l10n_gt_payroll_report.view_payslip_form_gt_quincena"/>
        <field name="arch" type="xml">
            <field name="struct_id" position="after">
                <field name="l10n_gt_is_settlement"/>
                <field name="l10n_gt_termination_reason"
                       invisible="not l10n_gt_is_settlement"
                       required="l10n_gt_is_settlement"/>
                <field name="l10n_gt_settlement_indemnity"
                       invisible="not l10n_gt_is_settlement"/>
                <field name="l10n_gt_settlement_years"
                       invisible="not l10n_gt_is_settlement"/>
            </field>

            <xpath expr="//header" position="inside">
                <button name="action_l10n_gt_compute_settlement" type="object"
                        string="Calcular finiquito" class="btn-primary"
                        invisible="not l10n_gt_is_settlement"
                        confirm="Esto recalcula las líneas del finiquito (salario, prestaciones e indemnización). ¿Continuar?"/>
            </xpath>

            <xpath expr="//field[@name='l10n_gt_pending_amount']" position="after">
                <field name="l10n_gt_settlement_total"
                       invisible="not l10n_gt_is_settlement"/>
            </xpath>
        </field>
    </record>

    <!-- Acción/menú de finiquitos: recibos marcados como liquidación. -->
    <record id="action_settlement_payslips" model="ir.actions.act_window">
        <field name="name">Liquidaciones / Finiquitos</field>
        <field name="res_model">hr.payslip</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('l10n_gt_is_settlement', '=', True)]</field>
        <field name="context">{'default_l10n_gt_is_settlement': True}</field>
    </record>

</odoo>
