<?xml version="1.0" encoding="utf-8"?>
<!-- Sin noupdate: las reglas son código y deben actualizarse en cada upgrade.
     La secuencia conserva su number_next (campo no presente en el XML). -->
<odoo>

    <!-- 4.11 Anticipos formales (con plan de cuotas). Los anticipos de sueldo
         flexibles se recuperan como líneas del Estado de Cuenta (reducen las
         quincenas), no por esta regla. -->
    <record id="rule_antic" model="hr.salary.rule">
        <field name="name">Anticipos</field>
        <field name="code">ANTIC</field>
        <field name="sequence">130</field>
        <field name="category_id" ref="hr_payroll.DED"/>
        <field name="struct_id" ref="l10n_gt_payroll.structure_gt_ordinaria"/>
        <field name="condition_select">python</field>
        <field name="condition_python">result = payslip._l10n_gt_loan_deduction('advance') > 0</field>
        <field name="amount_select">code</field>
        <field name="amount_python_compute">result = -payslip._l10n_gt_loan_deduction('advance')</field>
    </record>

    <!-- 4.12 Préstamos -->
    <record id="rule_prest" model="hr.salary.rule">
        <field name="name">Préstamos</field>
        <field name="code">PREST</field>
        <field name="sequence">140</field>
        <field name="category_id" ref="hr_payroll.DED"/>
        <field name="struct_id" ref="l10n_gt_payroll.structure_gt_ordinaria"/>
        <field name="condition_select">python</field>
        <field name="condition_python">result = payslip._l10n_gt_loan_deduction('loan') > 0</field>
        <field name="amount_select">code</field>
        <field name="amount_python_compute">result = -payslip._l10n_gt_loan_deduction('loan')</field>
    </record>

    <record id="seq_l10n_gt_loan" model="ir.sequence">
        <field name="name">Préstamos y anticipos GT</field>
        <field name="code">l10n.gt.loan</field>
        <field name="prefix">PA/</field>
        <field name="padding">5</field>
    </record>

</odoo>
