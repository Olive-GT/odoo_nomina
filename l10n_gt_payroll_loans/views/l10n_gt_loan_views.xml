<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_loan_form" model="ir.ui.view">
        <field name="name">l10n.gt.loan.form</field>
        <field name="model">l10n.gt.loan</field>
        <field name="arch" type="xml">
            <form string="Préstamo / Anticipo">
                <header>
                    <button name="action_confirm" string="Confirmar" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_suspend" string="Suspender" type="object"
                            invisible="state != 'active'"/>
                    <button name="action_reactivate" string="Reactivar" type="object"
                            invisible="state != 'suspended'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="loan_type"/>
                            <field name="date_grant"/>
                        </group>
                        <group>
                            <field name="amount"/>
                            <field name="installments"/>
                            <field name="amount_paid"/>
                            <field name="balance"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <field name="line_ids">
                        <list editable="bottom">
                            <field name="sequence"/>
                            <field name="due_date"/>
                            <field name="amount"/>
                            <field name="state"/>
                            <field name="payslip_id"/>
                            <field name="paid_date"/>
                            <field name="currency_id" column_invisible="1"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_loan_list" model="ir.ui.view">
        <field name="name">l10n.gt.loan.list</field>
        <field name="model">l10n.gt.loan</field>
        <field name="arch" type="xml">
            <list string="Préstamos y anticipos">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="loan_type"/>
                <field name="date_grant"/>
                <field name="amount"/>
                <field name="balance"/>
                <field name="state" widget="badge"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_loan_search" model="ir.ui.view">
        <field name="name">l10n.gt.loan.search</field>
        <field name="model">l10n.gt.loan</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <filter name="loans" string="Préstamos" domain="[('loan_type','=','loan')]"/>
                <filter name="advances" string="Anticipos" domain="[('loan_type','=','advance')]"/>
                <filter name="active" string="Activos" domain="[('state','=','active')]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="g_employee" string="Empleado" context="{'group_by':'employee_id'}"/>
                    <filter name="g_type" string="Tipo" context="{'group_by':'loan_type'}"/>
                    <filter name="g_state" string="Estado" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_loan" model="ir.actions.act_window">
        <field name="name">Préstamos y anticipos</field>
        <field name="res_model">l10n.gt.loan</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
