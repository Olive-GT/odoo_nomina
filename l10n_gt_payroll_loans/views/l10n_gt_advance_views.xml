<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Los anticipos se manejan como líneas del Estado de Cuenta (tipos
         'Anticipo entregado' y 'Recuperación de anticipo'), igual que Bono 14 /
         Aguinaldo. Aquí solo se muestra el saldo pendiente en el Resumen. -->
    <record id="view_payslip_form_gt_advance" model="ir.ui.view">
        <field name="name">hr.payslip.form.gt.advance</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id"
               ref="l10n_gt_payroll_report.view_payslip_form_gt_quincena"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='l10n_gt_pending_amount']" position="after">
                <field name="l10n_gt_advance_pending"
                       invisible="l10n_gt_advance_pending == 0"/>
            </xpath>
        </field>
    </record>

</odoo>
