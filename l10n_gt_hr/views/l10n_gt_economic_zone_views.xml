<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_l10n_gt_economic_zone_form" model="ir.ui.view">
        <field name="name">l10n.gt.economic.zone.form</field>
        <field name="model">l10n.gt.economic.zone</field>
        <field name="arch" type="xml">
            <form string="Circunscripción económica">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="active" widget="boolean_toggle"/>
                    </group>
                    <field name="minimum_wage_ids">
                        <list editable="bottom">
                            <field name="date_from"/>
                            <field name="amount"/>
                            <field name="currency_id" column_invisible="1"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_l10n_gt_economic_zone_list" model="ir.ui.view">
        <field name="name">l10n.gt.economic.zone.list</field>
        <field name="model">l10n.gt.economic.zone</field>
        <field name="arch" type="xml">
            <list string="Circunscripciones económicas">
                <field name="code"/>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="action_l10n_gt_economic_zone" model="ir.actions.act_window">
        <field name="name">Circunscripciones económicas</field>
        <field name="res_model">l10n.gt.economic.zone</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_l10n_gt_economic_zone"
              name="Circunscripciones económicas"
              parent="hr.menu_human_resources_configuration"
              action="action_l10n_gt_economic_zone"
              sequence="90"/>

</odoo>
