<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_contract_form_l10n_gt" model="ir.ui.view">
        <field name="name">hr.contract.form.l10n.gt</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Nómina Guatemala" name="l10n_gt_payroll">
                    <group>
                        <group string="Salario">
                            <field name="l10n_gt_salary_type"/>
                            <field name="l10n_gt_bonif_incentivo"/>
                            <field name="l10n_gt_first_quincena_amount"/>
                            <field name="l10n_gt_economic_zone_id"/>
                            <field name="l10n_gt_exclude_overtime"/>
                        </group>
                        <group string="Documentación">
                            <field name="l10n_gt_contract_pdf"
                                   filename="l10n_gt_contract_pdf_name"/>
                            <field name="l10n_gt_contract_pdf_name" invisible="1"/>
                        </group>
                    </group>
                </page>
            </notebook>
        </field>
    </record>

</odoo>
