<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_benefit_run_form" model="ir.ui.view">
        <field name="name">l10n.gt.benefit.run.form</field>
        <field name="model">l10n.gt.benefit.run</field>
        <field name="arch" type="xml">
            <form string="Planilla de prestación">
                <header>
                    <button name="action_compute" string="Calcular" type="object"
                            class="btn-primary" invisible="state == 'confirmed'"/>
                    <button name="action_confirm" string="Confirmar" type="object"
                            invisible="state != 'computed'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="benefit_type"/>
                            <field name="year"/>
                        </group>
                        <group>
                            <field name="date_from" readonly="1"/>
                            <field name="date_to" readonly="1"/>
                            <field name="total_amount"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <field name="line_ids">
                        <list>
                            <field name="employee_id"/>
                            <field name="dpi"/>
                            <field name="date_start"/>
                            <field name="worked_days"/>
                            <field name="average_salary"/>
                            <field name="amount_full"/>
                            <field name="amount" sum="Total"/>
                            <field name="currency_id" column_invisible="1"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_benefit_run_list" model="ir.ui.view">
        <field name="name">l10n.gt.benefit.run.list</field>
        <field name="model">l10n.gt.benefit.run</field>
        <field name="arch" type="xml">
            <list string="Planillas de prestaciones">
                <field name="name"/>
                <field name="benefit_type"/>
                <field name="year"/>
                <field name="total_amount"/>
                <field name="state" widget="badge"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="action_benefit_run" model="ir.actions.act_window">
        <field name="name">Aguinaldo / Bono 14</field>
        <field name="res_model">l10n.gt.benefit.run</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_vacation_taken" model="ir.actions.act_window">
        <field name="name">Vacaciones gozadas</field>
        <field name="res_model">l10n.gt.vacation.taken</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
