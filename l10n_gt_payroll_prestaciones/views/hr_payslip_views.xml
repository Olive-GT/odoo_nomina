<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vacaciones gozadas del período, junto a 'Faltas' (misma lógica: solo se
         marcan las excepciones al 'trabajó todos los días'). -->
    <record id="view_payslip_form_gt_vacation" model="ir.ui.view">
        <field name="name">hr.payslip.form.gt.vacation</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id"
               ref="l10n_gt_payroll_report.view_payslip_form_gt_quincena"/>
        <field name="arch" type="xml">
            <field name="l10n_gt_unpaid_days" position="after">
                <field name="l10n_gt_vacation_days"/>
            </field>
        </field>
    </record>

</odoo>
