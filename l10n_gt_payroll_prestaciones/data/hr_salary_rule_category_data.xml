         propia para que la póliza contable las agrupe/mapee a sus cuentas. -->
    <record id="GT_PROVISION" model="hr.salary.rule.category">
        <field name="name">Provisiones / Pasivo laboral (Guatemala)</field>
        <field name="code">GT_PROVISION</field>
    </record>

</odoo>
