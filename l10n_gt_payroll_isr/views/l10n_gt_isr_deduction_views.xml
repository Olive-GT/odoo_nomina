<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_isr_deduction_form" model="ir.ui.view">
        <field name="name">l10n.gt.isr.deduction.form</field>
        <field name="model">l10n.gt.isr.deduction</field>
        <field name="arch" type="xml">
            <form string="Deducción comprobable ISR">
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="year"/>
                            <field name="deduction_type"/>
                        </group>
                        <group>
                            <field name="amount"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="description"/>
                        </group>
                    </group>
                    <field name="attachment_ids" widget="many2many_binary"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_isr_deduction_list" model="ir.ui.view">
        <field name="name">l10n.gt.isr.deduction.list</field>
        <field name="model">l10n.gt.isr.deduction</field>
        <field name="arch" type="xml">
            <list string="Deducciones comprobables" editable="bottom">
                <field name="employee_id"/>
                <field name="year"/>
                <field name="deduction_type"/>
                <field name="amount"/>
                <field name="description"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="action_isr_deduction" model="ir.actions.act_window">
        <field name="name">Deducciones comprobables ISR</field>
        <field name="res_model">l10n.gt.isr.deduction</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
