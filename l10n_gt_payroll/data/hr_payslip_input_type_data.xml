<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Tipos de novedad importables (§2.4 / §3.3.2 "Importar novedades") -->
    <record id="input_he_diurna" model="hr.payslip.input.type">
        <field name="name">Horas extra diurnas</field>
        <field name="code">HE_DIURNA</field>
    </record>
    <record id="input_he_nocturna" model="hr.payslip.input.type">
        <field name="name">Horas extra nocturnas</field>
        <field name="code">HE_NOCTURNA</field>
    </record>
    <record id="input_comisiones" model="hr.payslip.input.type">
        <field name="name">Comisiones</field>
        <field name="code">COMIS</field>
    </record>
    <record id="input_bonif_adicional" model="hr.payslip.input.type">
        <field name="name">Bonificaciones adicionales</field>
        <field name="code">BONIF</field>
    </record>
    <record id="input_otras_deducciones" model="hr.payslip.input.type">
        <field name="name">Otras deducciones</field>
        <field name="code">OTRDED</field>
    </record>

    <!-- Anticipo de sueldo del propio mes: se registra como entrada en el recibo
         y se descuenta directo, sin necesidad de crear un préstamo formal. -->
    <record id="input_anticipo" model="hr.payslip.input.type">
        <field name="name">Anticipo de sueldo</field>
        <field name="code">ANTICIPO</field>
    </record>

</odoo>
