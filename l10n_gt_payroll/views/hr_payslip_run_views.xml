<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_payslip_run_form_l10n_gt" model="ir.ui.view">
        <field name="name">hr.payslip.run.form.l10n.gt</field>
        <field name="model">hr.payslip.run</field>
        <field name="inherit_id" ref="hr_payroll.hr_payslip_run_form"/>
        <field name="arch" type="xml">
            <header position="inside">
                <button name="action_gt_compute" string="Calcular nómina"
                        type="object" class="btn-primary"
                        invisible="l10n_gt_state not in ('draft', 'computing')"
                        groups="l10n_gt_payroll.group_payroll_user"/>
                <button name="action_gt_confirm" string="Confirmar"
                        type="object" class="btn-primary"
                        invisible="l10n_gt_state != 'computed'"
                        groups="l10n_gt_payroll.group_payroll_user"/>
                <button name="action_gt_post" string="Contabilizar"
                        type="object"
                        invisible="l10n_gt_state != 'confirmed'"
                        groups="l10n_gt_payroll.group_payroll_manager"/>
                <button name="action_gt_close" string="Cerrar período"
                        type="object"
                        invisible="l10n_gt_state != 'posted'"
                        groups="l10n_gt_payroll.group_payroll_manager"/>
                <button name="action_gt_reopen" string="Reabrir"
                        type="object"
                        invisible="l10n_gt_state != 'closed'"
                        groups="l10n_gt_payroll.group_payroll_manager"/>
                <field name="l10n_gt_state" widget="statusbar"
                       statusbar_visible="draft,computed,confirmed,posted,closed"/>
            </header>
            <field name="date_end" position="after">
                <field name="l10n_gt_structure_type_id"/>
            </field>
        </field>
    </record>

</odoo>
