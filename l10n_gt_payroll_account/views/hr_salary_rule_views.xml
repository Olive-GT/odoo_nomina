<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_salary_rule_form_gt_account" model="ir.ui.view">
        <field name="name">hr.salary.rule.form.gt.account</field>
        <field name="model">hr.salary.rule</field>
        <field name="inherit_id" ref="hr_payroll.hr_salary_rule_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Contabilidad GT" name="l10n_gt_account">
                    <group>
                        <field name="l10n_gt_account_debit_id"/>
                        <field name="l10n_gt_account_credit_id"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
